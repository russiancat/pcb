(kicad_pcb
  (version 20221018)
  (generator pcbnew)

  (net 0 "")
  (net 1 "VCC")
  (net 2 "GND")
  (net 3 "/RESET")
  (net 4 "/PB3")
  (net 5 "/PB4")
  (net 6 "/PB0")
  (net 7 "/PB1")
  (net 8 "/PB2")
  (net 9 "/LED_SIG")

  (footprint "Connector:PinHeader_2.54mm" (layer "F.Cu")
    (at 5 25)
    (fp_text reference "J1" (at 0 -3) (layer "F.SilkS"))
    (fp_text value "PWR" (at 0 3) (layer "F.Fab"))
    (pad "1" thru_hole circle (at 0 -1.27) (size 1.7 1.7) (drill 1.0)
      (layers "*.Cu" "*.Mask")
      (net 1 "VCC"))
    (pad "2" thru_hole circle (at 0 1.27) (size 1.7 1.7) (drill 1.0)
      (layers "*.Cu" "*.Mask")
      (net 2 "GND"))
  )

  (footprint "Package_DIP:DIP-8_W7.62mm" (layer "F.Cu")
    (at 25 25)
    (fp_text reference "U1" (at 0 -6) (layer "F.SilkS"))
    (fp_text value "ATtiny85" (at 0 6) (layer "F.Fab"))
    (pad "1" thru_hole oval (at -3.81 -3.81) (size 1.6 1.6) (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 3 "/RESET"))
    (pad "2" thru_hole oval (at -3.81 -1.27) (size 1.6 1.6) (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 4 "/PB3"))
    (pad "3" thru_hole oval (at -3.81 1.27) (size 1.6 1.6) (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 5 "/PB4"))
    (pad "4" thru_hole oval (at -3.81 3.81) (size 1.6 1.6) (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 2 "GND"))
    (pad "5" thru_hole oval (at 3.81 3.81) (size 1.6 1.6) (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 6 "/PB0"))
    (pad "6" thru_hole oval (at 3.81 1.27) (size 1.6 1.6) (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 7 "/PB1"))
    (pad "7" thru_hole oval (at 3.81 -1.27) (size 1.6 1.6) (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 8 "/PB2"))
    (pad "8" thru_hole oval (at 3.81 -3.81) (size 1.6 1.6) (drill 0.8)
      (layers "*.Cu" "*.Mask")
      (net 1 "VCC"))
  )

  (footprint "Capacitor_SMD:C_0805" (layer "F.Cu")
    (at 34 18)
    (fp_text reference "C1" (at 0 -2) (layer "F.SilkS"))
    (fp_text value "100nF" (at 0 2) (layer "F.Fab"))
    (pad "1" smd rect (at -1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "VCC"))
    (pad "2" smd rect (at 1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "GND"))
  )

  (footprint "Capacitor_SMD:C_0805" (layer "F.Cu")
    (at 16 35)
    (fp_text reference "C2" (at 0 -2) (layer "F.SilkS"))
    (fp_text value "100nF" (at 0 2) (layer "F.Fab"))
    (pad "1" smd rect (at -1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "VCC"))
    (pad "2" smd rect (at 1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "GND"))
  )

  (footprint "Resistor_SMD:R_0805" (layer "F.Cu")
    (at 16 12)
    (fp_text reference "R1" (at 0 -2) (layer "F.SilkS"))
    (fp_text value "10k" (at 0 2) (layer "F.Fab"))
    (pad "1" smd rect (at -1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "VCC"))
    (pad "2" smd rect (at 1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 3 "/RESET"))
  )

  (footprint "Resistor_SMD:R_0805" (layer "F.Cu")
    (at 40 24)
    (fp_text reference "R2" (at 0 -2) (layer "F.SilkS"))
    (fp_text value "330R" (at 0 2) (layer "F.Fab"))
    (pad "1" smd rect (at -1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 4 "/PB3"))
    (pad "2" smd rect (at 1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 9 "/LED_SIG"))
  )

  (footprint "LED_SMD:LED_0805" (layer "F.Cu")
    (at 50 30)
    (fp_text reference "LED1" (at 0 -2) (layer "F.SilkS"))
    (fp_text value "RED" (at 0 2) (layer "F.Fab"))
    (pad "1" smd rect (at -1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 9 "/LED_SIG"))
    (pad "2" smd rect (at 1.0 0) (size 1.3 1.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "GND"))
  )

  (footprint "Connector:PinHeader_2.54mm" (layer "F.Cu")
    (at 55 24)
    (fp_text reference "J2" (at 3 0) (layer "F.SilkS"))
    (fp_text value "IO" (at -3 0) (layer "F.Fab"))
    (pad "1" thru_hole circle (at 0 -3.81) (size 1.7 1.7) (drill 1.0)
      (layers "*.Cu" "*.Mask")
      (net 6 "/PB0"))
    (pad "2" thru_hole circle (at 0 -1.27) (size 1.7 1.7) (drill 1.0)
      (layers "*.Cu" "*.Mask")
      (net 7 "/PB1"))
    (pad "3" thru_hole circle (at 0 1.27) (size 1.7 1.7) (drill 1.0)
      (layers "*.Cu" "*.Mask")
      (net 8 "/PB2"))
    (pad "4" thru_hole circle (at 0 3.81) (size 1.7 1.7) (drill 1.0)
      (layers "*.Cu" "*.Mask")
      (net 5 "/PB4"))
  )

  (gr_rect (start 0 0) (end 60 50) (layer "Edge.Cuts") (width 0.05))
)
